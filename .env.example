# ─────────────────────────────────────────────────────────────
#  FurniCraft 3D — server configuration
#  Copy this file to ".env" and fill in your values.
# ─────────────────────────────────────────────────────────────

# Port the server listens on (Render sets this automatically)
PORT=3000

# ── PostgreSQL ───────────────────────────────────────────────
# Full connection string. Examples:
#   Local:  postgresql://postgres:password@localhost:5432/furnicraft
#   Render: copy the "Internal Database URL" from your Render Postgres dashboard
DATABASE_URL=postgresql://postgres:password@localhost:5432/furnicraft

# Set to "true" when connecting to a managed Postgres that requires SSL
# (Render, Heroku, Supabase, etc.). Leave "false" for local Postgres.
DATABASE_SSL=false

# ── Auth ─────────────────────────────────────────────────────
# Secret used to sign JWT session tokens. Use a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret

# How long a login session lasts
JWT_EXPIRES_IN=30d

# ── Google Sign-In (optional) ────────────────────────────────
# OAuth 2.0 Web Client ID from https://console.cloud.google.com
# Leave blank to disable the "Continue with Google" button.
GOOGLE_CLIENT_ID=

# ── Email OTP verification (optional) ────────────────────────
# SMTP credentials used to send the 6-digit verification code.
# For Gmail: create an "App Password" at https://myaccount.google.com/apppasswords
# Leave SMTP_USER blank to run in DEV mode (the code is returned in the
# API response and shown in the UI instead of being emailed).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="FurniCraft 3D <no-reply@furnicraft.app>"
